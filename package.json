{
  "name": "sd-plugins",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "com.isrudoy.mactools.sdPlugin",
    "com.isrudoy.unifi.sdPlugin"
  ],
  "description": "StreamDock plugins for macOS",
  "scripts": {
    "lint": "eslint .",
    "fmt": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "restart": "pkill -f 'node.*com.isrudoy.*sdPlugin'; pkill -x StreamDock; sleep 1; open -a StreamDock",
    "link": "npm run link:mactools && npm run link:unifi",
    "link:mactools": "ln -sf \"$(pwd)/com.isrudoy.mactools.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.mactools.sdPlugin\"",
    "link:unifi": "ln -sf \"$(pwd)/com.isrudoy.unifi.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.unifi.sdPlugin\"",
    "unlink": "rm -f \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.mactools.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.unifi.sdPlugin\""
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/node": "20.17.0",
    "@types/ws": "8.18.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.3",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3"
  },
  "author": "isrudoy",
  "license": "MIT"
}
