{
  "name": "sd-plugins",
  "version": "1.2.1",
  "private": true,
  "description": "StreamDock plugins",
  "scripts": {
    "lint": "eslint .",
    "fmt": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "restart": "pkill -f 'node.*com.isrudoy.*sdPlugin'; pkill -x StreamDock; sleep 1; open -a StreamDock",
    "link": "npm run link:mactools && npm run link:unifi && npm run link:spruthub && npm run link:acontrol && npm run link:antelope",
    "link:mactools": "ln -sf \"$(pwd)/com.isrudoy.mactools.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.mactools.sdPlugin\"",
    "link:unifi": "ln -sf \"$(pwd)/com.isrudoy.unifi.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.unifi.sdPlugin\"",
    "link:spruthub": "ln -sf \"$(pwd)/com.isrudoy.spruthub.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.spruthub.sdPlugin\"",
    "link:acontrol": "ln -sf \"$(pwd)/com.isrudoy.acontrol.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.acontrol.sdPlugin\"",
    "link:antelope": "ln -sf \"$(pwd)/com.isrudoy.antelope.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.antelope.sdPlugin\"",
    "unlink": "rm -f \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.mactools.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.unifi.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.spruthub.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.acontrol.sdPlugin\" \"$HOME/Library/Application Support/HotSpot/StreamDock/plugins/com.isrudoy.antelope.sdPlugin\"",
    "link:win": "npm run link:win:spruthub && npm run link:win:unifi && npm run link:win:wintools && npm run link:win:acontrol && npm run link:win:antelope",
    "link:win:spruthub": "cmd.exe /c \"$(wslpath -w scripts/link-win.cmd)\" com.isrudoy.spruthub",
    "link:win:unifi": "cmd.exe /c \"$(wslpath -w scripts/link-win.cmd)\" com.isrudoy.unifi",
    "link:win:wintools": "cmd.exe /c \"$(wslpath -w scripts/link-win.cmd)\" com.isrudoy.wintools",
    "link:win:acontrol": "cmd.exe /c \"$(wslpath -w scripts/link-win.cmd)\" com.isrudoy.acontrol",
    "link:win:antelope": "cmd.exe /c \"$(wslpath -w scripts/link-win.cmd)\" com.isrudoy.antelope",
    "install:all": "for d in com.isrudoy.*.sdPlugin; do (cd \"$d\" && npm install); done",
    "install:all:win": "for d in com.isrudoy.*.sdPlugin; do (cd \"$d\" && npm install && npm install --os=win32 --cpu=x64); done"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/multicast-dns": "7.2.4",
    "@types/node": "20.17.0",
    "@types/ws": "8.18.1",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.3",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3"
  },
  "author": "isrudoy",
  "license": "MIT"
}
