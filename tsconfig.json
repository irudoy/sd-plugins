{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "com.isrudoy.*/plugin/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "old",
    "reference",
    "**/static"
  ]
}
